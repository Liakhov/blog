---
export const prerender = true;

import { getCollection } from 'astro:content';
import HomeLayout from '@/layouts/HomeLayout.astro';
import Card from '@/components/Card.astro';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const sortedPosts = posts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);
---

<HomeLayout>
  <h4>Hi, I'm Yurii 👋🏻</h4>
  <p>
    I am a Software Engineer from Ukraine. I work with Angular, SvelteKit, TypeScript, Node.js, and
    Prisma across the full stack. Here I share practical things I've picked up while building real
    projects — and my experiments with AI tooling along the way.
  </p>

  <ul slot="recent-posts">
    {sortedPosts.map(post => <Card {...post} />)}
  </ul>
</HomeLayout>
