---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import ArrowLeft from '@/assets/icons/arrow-left.svg';
import { SITE } from '@/consts';
---

<BaseLayout title={`404 Not Found | ${SITE.title}`} noindex>
  <Header />

  <main id="main-content" class="wrapper flex flex-1 items-center justify-center">
    <div class="mb-14 flex flex-col items-center justify-center">
      <h1 class="text-3xl font-bold sm:text-4xl">404</h1>
      <p class="mt-4">Page Not Found</p>
      <div class="mt-6 flex items-center justify-between gap-x-2">
        <ArrowLeft class="size-4" />
        <a href="/"> Go back home </a>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
