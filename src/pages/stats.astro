---
import { env } from 'cloudflare:workers';
import { SITE } from '@/consts';
import { getDashboardData } from '@/lib/analytics/dashboard-stats';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import StatCard from '@/components/stats/StatsCard.astro';
import StatsSection from '@/components/stats/StatsSection.astro';
import DailyTable from '@/components/stats/StatsDailyTable.astro';

const dashboardData = await getDashboardData(env.DB);

const statsData = {
  ...dashboardData,
  maxLivePageViews: dashboardData.liveTodayPages[0]?.views ?? 1,
  maxPages30dViews: dashboardData.topPages30d[0]?.views ?? 1,
  maxPagesAllTimeViews: dashboardData.topPagesAllTime[0]?.views ?? 1,
  maxReferrerHits: dashboardData.topReferrers30d[0]?.hits ?? 1,
  maxBrowserHits: dashboardData.topBrowsers30d[0]?.hits ?? 1,
  maxCountryHits: dashboardData.topCountries30d[0]?.hits ?? 1
};
---

<BaseLayout title={`Stats | ${SITE.title}`} description="Site analytics" noindex>
  <Header />
  <main class="wrapper mt-4 mb-12">
    <h1 class="text-2xl font-semibold">Stats</h1>
    <p class="mt-1 text-sm text-muted-foreground">
      Privacy-first, server-side tracking — no cookies, no client-side scripts. Rollup-backed
      sections lag by ~2 days; the live section reads raw events.
    </p>

    <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-5">
      <StatCard
        label="Live (today)"
        views={statsData.liveTodayTotals.views}
        visitors={statsData.liveTodayTotals.visitors}
      />
      <StatCard
        label="Yesterday"
        views={statsData.yesterday.views}
        visitors={statsData.yesterday.visitors}
      />
      <StatCard
        label="7 days"
        views={statsData.total7Days.views}
        visitors={statsData.total7Days.visitors}
      />
      <StatCard
        label="30 days"
        views={statsData.total30Days.views}
        visitors={statsData.total30Days.visitors}
      />
      <StatCard
        label="All time"
        views={statsData.totalAllTime.views}
        visitors={statsData.totalAllTime.visitors}
        class="col-span-2 sm:col-span-3 lg:col-span-1"
      />
    </div>

    <StatsSection
      title="Live"
      period="today, raw"
      items={statsData.liveTodayPages.map(r => ({ label: r.path, value: r.views }))}
      max={statsData.maxLivePageViews}
      emptyText="No traffic yet today"
    />

    <DailyTable title="Last 7 Days" rows={statsData.last7Days} />
    <DailyTable title="Last 30 Days" rows={statsData.last30Days} scrollable />

    <div class="mt-10 grid gap-10 lg:grid-cols-2">
      <StatsSection
        title="Top Pages"
        period="30 days"
        items={statsData.topPages30d.map(r => ({ label: r.path, value: r.views }))}
        max={statsData.maxPages30dViews}
      />
      <StatsSection
        title="Top Pages"
        period="all time"
        items={statsData.topPagesAllTime.map(r => ({ label: r.path, value: r.views }))}
        max={statsData.maxPagesAllTimeViews}
      />
    </div>

    <StatsSection
      title="Referrers"
      period="30 days"
      items={statsData.topReferrers30d.map(r => ({ label: r.referrer, value: r.hits }))}
      max={statsData.maxReferrerHits}
    />

    <div class="mt-10 grid gap-10 sm:grid-cols-2">
      <StatsSection
        title="Browsers"
        period="30 days"
        items={statsData.topBrowsers30d.map(r => ({ label: r.browser, value: r.hits }))}
        max={statsData.maxBrowserHits}
      />
      <StatsSection
        title="Countries"
        period="30 days"
        items={statsData.topCountries30d.map(r => ({ label: r.country, value: r.hits }))}
        max={statsData.maxCountryHits}
      />
    </div>
  </main>
  <Footer />
</BaseLayout>
