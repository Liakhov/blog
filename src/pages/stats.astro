---
import { env } from 'cloudflare:workers';
import { SITE } from '@/consts';
import { getDashboardData } from '@/lib/analytics/db';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import StatsList from '@/components/StatsList.astro';

const db = (env as unknown as CloudflareEnv).DB;
const data = await getDashboardData(db);

const totalViews7d = data.last7Days.reduce((sum, r) => sum + r.views, 0);
const totalVisitors7d = data.last7Days.reduce((sum, r) => sum + r.visitors, 0);
const totalViews30d = data.last30Days.reduce((sum, r) => sum + r.views, 0);
const totalVisitors30d = data.last30Days.reduce((sum, r) => sum + r.visitors, 0);
const allTimeViews = data.topPages.reduce((s, r) => s + r.views, 0);
const allTimeVisitors = data.topPages.reduce((s, r) => s + r.visitors, 0);

const maxPageViews = data.topPages.length > 0 ? data.topPages[0].views : 1;
const maxReferrerHits = data.topReferrers.length > 0 ? data.topReferrers[0].hits : 1;
const maxBrowserHits = data.browsers.length > 0 ? data.browsers[0].hits : 1;
const maxCountryHits = data.countries.length > 0 ? data.countries[0].hits : 1;
---

<BaseLayout title={`Stats | ${SITE.title}`} description="Site analytics" noindex>
  <Header />
  <main class="wrapper mt-4 mb-12">
    <h1 class="text-2xl font-semibold">Stats</h1>
    <p class="mt-1 text-sm text-muted-foreground">
      Privacy-first, server-side tracking — no cookies, no client-side scripts.
    </p>

    {/* Overview Cards */}
    <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="rounded-lg bg-surface p-4">
        <p class="text-xs text-muted-foreground">Today</p>
        <p class="mt-1 text-2xl font-semibold tabular-nums">{data.today?.views ?? 0}</p>
        <p class="text-xs text-muted-foreground">{data.today?.visitors ?? 0} visitors</p>
      </div>
      <div class="rounded-lg bg-surface p-4">
        <p class="text-xs text-muted-foreground">7 days</p>
        <p class="mt-1 text-2xl font-semibold tabular-nums">{totalViews7d}</p>
        <p class="text-xs text-muted-foreground">{totalVisitors7d} visitors</p>
      </div>
      <div class="rounded-lg bg-surface p-4">
        <p class="text-xs text-muted-foreground">30 days</p>
        <p class="mt-1 text-2xl font-semibold tabular-nums">{totalViews30d}</p>
        <p class="text-xs text-muted-foreground">{totalVisitors30d} visitors</p>
      </div>
      <div class="rounded-lg bg-surface p-4">
        <p class="text-xs text-muted-foreground">All time</p>
        <p class="mt-1 text-2xl font-semibold tabular-nums">{allTimeViews}</p>
        <p class="text-xs text-muted-foreground">{allTimeVisitors} visitors</p>
      </div>
    </div>

    {/* Last 7 Days Table */}
    <section class="mt-10">
      <h2 class="text-base font-semibold">Last 7 Days</h2>
      {data.last7Days.length > 0 ? (
        <div class="mt-3 overflow-x-auto rounded-lg border border-border">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-border bg-surface [&_th]:text-muted-foreground [&_th]:font-medium [&_th]:text-xs">
                <th class="px-4 py-2.5 text-left">Date</th>
                <th class="px-4 py-2.5 text-right">Views</th>
                <th class="px-4 py-2.5 text-right">Visitors</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border">
              {data.last7Days.slice().reverse().map(row => (
                <tr class="[&_td]:px-4 [&_td]:py-2.5">
                  <td>{row.date}</td>
                  <td class="text-right tabular-nums">{row.views}</td>
                  <td class="text-right tabular-nums text-muted-foreground">{row.visitors}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <p class="mt-3 text-sm text-muted-foreground">No data yet</p>
      )}
    </section>

    {/* Last 30 Days Table */}
    <section class="mt-10">
      <h2 class="text-base font-semibold">Last 30 Days</h2>
      {data.last30Days.length > 0 ? (
        <div class="mt-3 max-h-80 overflow-y-auto rounded-lg border border-border">
          <table class="w-full text-sm">
            <thead class="sticky top-0">
              <tr class="border-b border-border bg-surface [&_th]:text-muted-foreground [&_th]:font-medium [&_th]:text-xs">
                <th class="px-4 py-2.5 text-left">Date</th>
                <th class="px-4 py-2.5 text-right">Views</th>
                <th class="px-4 py-2.5 text-right">Visitors</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border">
              {data.last30Days.slice().reverse().map(row => (
                <tr class="[&_td]:px-4 [&_td]:py-2.5">
                  <td>{row.date}</td>
                  <td class="text-right tabular-nums">{row.views}</td>
                  <td class="text-right tabular-nums text-muted-foreground">{row.visitors}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <p class="mt-3 text-sm text-muted-foreground">No data yet</p>
      )}
    </section>

    {/* Top Pages */}
    <section class="mt-10">
      <h2 class="text-base font-semibold">Top Pages <span class="text-sm font-normal text-muted-foreground">all time</span></h2>
      {data.topPages.length > 0 ? (
        <StatsList items={data.topPages.map(r => ({ label: r.path, value: r.views }))} max={maxPageViews} />
      ) : (
        <p class="mt-3 text-sm text-muted-foreground">No data yet</p>
      )}
    </section>

    {/* Referrers */}
    <section class="mt-10">
      <h2 class="text-base font-semibold">Referrers <span class="text-sm font-normal text-muted-foreground">30 days</span></h2>
      {data.topReferrers.length > 0 ? (
        <StatsList items={data.topReferrers.map(r => ({ label: r.referrer, value: r.hits }))} max={maxReferrerHits} />
      ) : (
        <p class="mt-3 text-sm text-muted-foreground">No data yet</p>
      )}
    </section>

    {/* Browsers & Countries */}
    <div class="mt-10 grid gap-10 sm:grid-cols-2">
      <section>
        <h2 class="text-base font-semibold">Browsers <span class="text-sm font-normal text-muted-foreground">30 days</span></h2>
        {data.browsers.length > 0 ? (
          <StatsList items={data.browsers.map(r => ({ label: r.browser, value: r.hits }))} max={maxBrowserHits} />
        ) : (
          <p class="mt-3 text-sm text-muted-foreground">No data yet</p>
        )}
      </section>

      <section>
        <h2 class="text-base font-semibold">Countries <span class="text-sm font-normal text-muted-foreground">30 days</span></h2>
        {data.countries.length > 0 ? (
          <StatsList items={data.countries.map(r => ({ label: r.country, value: r.hits }))} max={maxCountryHits} />
        ) : (
          <p class="mt-3 text-sm text-muted-foreground">No data yet</p>
        )}
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>
