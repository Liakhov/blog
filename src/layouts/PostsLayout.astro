---
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { SITE } from '@/consts';

type Props = {
  title?: string;
  description?: string;
};

const { title = 'Posts', description } = Astro.props;
---

<BaseLayout title={`${title} | ${SITE.title}`} description={description ?? SITE.desc}>
  <Header />
  <main id="main-content" class="wrapper mb-12">
    <header class="pt-8 pb-6">
      <h1 class="text-2xl tracking-wider sm:text-3xl">{title}</h1>
      {description && <p class="mt-2 italic">{description}</p>}
    </header>
    <slot />
  </main>
  <Footer />
</BaseLayout>
