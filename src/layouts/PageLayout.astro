---
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { SITE } from '@/consts';

const props = Astro.props;

const { title, description } = 'frontmatter' in props ? props.frontmatter : props;
---

<BaseLayout title={`${title} | ${SITE.title}`} description={description}>
  <Header />
  <main id="main-content" class="wrapper mb-12">
    <article>
      <h1 class="text-2xl tracking-wider sm:text-3xl">{title}</h1>
      <slot />
    </article>
  </main>
  <Footer />
</BaseLayout>
