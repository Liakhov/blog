---
import { SITE } from '../consts';

const navLinks = [
  { href: '/posts', label: 'Posts' },
  { href: '/about', label: 'About' }
];
---

<header>
  <nav class="wrapper mb-4 flex items-center justify-between gap-4 py-5">
    <a class="text-lg font-semibold no-underline transition-colors duration-200" href="/">
      {SITE.title}
    </a>
    <div class="flex items-center gap-4 text-base">
      {
        navLinks.map(link => (
          <a
            href={link.href}
            class="text-muted-foreground transition-colors duration-200 hover:text-surface-foreground"
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>
