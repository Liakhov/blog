---
import { SITE } from '../consts';
import Moon from '@/assets/icons/moon.svg';
import Sun from '@/assets/icons/sun.svg';

const navLinks = [
  { href: '/posts', label: 'Posts' },
  { href: '/about', label: 'About' }
];
---

<header class="wrapper py-5">
  <nav class="flex items-center justify-between gap-4 border-b border-border pb-4">
    <a
      class="text-lg font-semibold text-foreground no-underline transition-colors duration-200"
      href="/"
    >
      {SITE.title}
    </a>
    <div class="flex items-center">
      <div class="flex items-center gap-5 text-base">
        {
          navLinks.map(link => (
            <a
              href={link.href}
              class="text-muted-foreground transition-colors duration-200 hover:text-surface-foreground"
            >
              {link.label}
            </a>
          ))
        }
      </div>
      <button
        id="theme-btn"
        type="button"
        class="ml-12 text-muted-foreground transition-all duration-200 hover:text-surface-foreground"
      >
        <Moon class="moon-icon hidden size-5" />
        <Sun class="sun-icon hidden size-5" />
      </button>
    </div>
  </nav>
</header>
